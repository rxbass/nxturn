build/
dist/

# Supabase local
.supabase/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Testing
coverage/

# Misc
*.log
